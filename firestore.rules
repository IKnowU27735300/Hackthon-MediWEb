rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─────────────────────────────────────────────────────────────────
    // HELPER FUNCTIONS
    // ─────────────────────────────────────────────────────────────────

    // Is the caller signed in?
    function isAuth() {
      return request.auth != null;
    }

    // Read the caller's own business profile
    function callerProfile() {
      return get(/databases/$(database)/documents/businesses/$(request.auth.uid)).data;
    }

    // Role shortcuts
    function isDoctor() {
      return isAuth() && callerProfile().role == 'doctor';
    }

    function isAssistant() {
      return isAuth() && callerProfile().role == 'assistant';
    }

    function isSupplier() {
      return isAuth() && callerProfile().role == 'supplier';
    }

    // Does the assistant belong to this clinic (businessId)?
    function assistantBelongsToClinic(businessId) {
      return isAssistant() && callerProfile().businessId == businessId;
    }

    // Is the caller the owner of this clinic?
    function isOwner(businessId) {
      return isAuth() && request.auth.uid == businessId;
    }

    // Is the caller either the clinic doctor OR an assistant linked to this clinic?
    function isClinicalStaff(businessId) {
      return isOwner(businessId) || assistantBelongsToClinic(businessId);
    }

    // Is the caller a supplier? (any supplier)
    function isAnySupplier() {
      return isAuth() && get(/databases/$(database)/documents/businesses/$(request.auth.uid)).data.role == 'supplier';
    }

    // ─────────────────────────────────────────────────────────────────
    // /businesses/{uid}  — Staff / Clinic profiles
    // ─────────────────────────────────────────────────────────────────
    match /businesses/{uid} {

      // Any signed-in user can LIST the businesses collection
      // (needed for staff discovery: finding doctors, suppliers, assistants)
      allow list: if true; // DEBUG: Open list to find UIDs

      // Anyone can read a clinic profile (needed for intake forms and portals)
      allow get: if true;

      // A user can only create/update their OWN profile
      allow create: if isAuth() && request.auth.uid == uid;
      allow update: if isAuth() && (
        request.auth.uid == uid ||
        // Doctors can update an assistant's businessId field to link them to their OWN clinic
        (isDoctor() && request.resource.data.businessId == request.auth.uid && 
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['businessId', 'status', 'lastActive']))
      );

      // Only the owner can delete their own profile
      allow delete: if isOwner(uid);

      // ── Sub-collections under a clinic ──────────────────────────────

      // BOOKINGS
      match /bookings/{bookingId} {
        // Doctor (owner) + linked assistant can read bookings
        allow read: if isClinicalStaff(uid);
        // Unauthenticated patients can CREATE bookings via the intake form
        allow create: if true;
        // Only clinical staff can update or delete bookings
        allow update: if isOwner(uid) || assistantBelongsToClinic(uid);
        allow delete: if isOwner(uid);
      }

      // CONTACTS (Patient records)
      match /contacts/{contactId} {
        // Staff can read/write; Patients can read/create (needed for duplicate checking in intake form)
        allow read: if true; 
        allow create: if true;
        allow update: if isClinicalStaff(uid);
        allow delete: if isOwner(uid);

        // Private sub-document (medical reports, sensitive notes)
        match /private/{docId} {
          // Assistants need read access for the Case Review modal
          allow read: if isClinicalStaff(uid);
          // Only the doctor can write clinical reports
          allow write: if isOwner(uid);
        }
      }

      // INVENTORY
      match /inventory/{itemId} {
        // All clinical staff + suppliers can read inventory
        allow read: if isClinicalStaff(uid) || isSupplier();
        // Clinical staff AND suppliers can write inventory
        allow create, update: if isClinicalStaff(uid) || isSupplier();
        allow delete: if isOwner(uid);
      }

      // STOCK HISTORY (prescription / supply requests)
      match /stock_history/{historyId} {
        // Doctor sees all; assistant sees all in clinic; supplier sees assigned OR pending requests
        allow read: if isClinicalStaff(uid)
          || (isSupplier() && (resource.data.supplierId == request.auth.uid || resource.data.status == 'pending'));

        // Doctor + assistant can create stock logs
        allow create: if isClinicalStaff(uid);

        // Doctor can update any record; 
        // Supplier can only update if assigned OR if claiming a pending request
        allow update: if isOwner(uid)
          || assistantBelongsToClinic(uid)
          || (isSupplier() && 
               (resource.data.supplierId == request.auth.uid || resource.data.status == 'pending') &&
               request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt', 'acceptedAt', 'supplierId', 'supplierName'])
             );

        allow delete: if isOwner(uid);
      }

      // CUSTOMER CHATS (Patient inbox threads)
      match /customer_chats/{customerEmail} {
        // Clinical staff can read/write everything
        allow read, write: if isClinicalStaff(uid);
        
        // Patients (authenticated or not) can GET, CREATE and UPDATE their chat metadata
        allow get, create, update: if true;

        match /messages/{messageId} {
          // Authenticated clinical staff can read/write messages
          allow read, write: if isClinicalStaff(uid);
          // Patients can READ and CREATE messages in their own thread
          allow read: if true;
          allow create: if true;
        }
      }

      // INTERNAL CHATS (Doctor ↔ Assistant briefings)
      match /internal_chats/{assistantId} {
        // Doctor can read all internal chats; assistant can only read their own thread
        allow read: if isOwner(uid) || (isAssistant() && request.auth.uid == assistantId);
        allow write: if isClinicalStaff(uid);

        match /messages/{messageId} {
          allow read: if isOwner(uid) || (isAssistant() && request.auth.uid == assistantId);
          allow create: if isClinicalStaff(uid);
          allow update, delete: if isOwner(uid);
        }
      }
    }

    // ─────────────────────────────────────────────────────────────────
    // COLLECTION GROUPS (Queries across multiple clinics)
    // ─────────────────────────────────────────────────────────────────
    
    // Suppliers need to search across all business/stock_history subcollections
    match /{path=**}/stock_history/{historyId} {
      allow read: if isAuth() && (
        resource.data.supplierId == request.auth.uid || 
        resource.data.status == 'pending' ||
        // Also allow clinical staff to read their own records via collection group if needed
        resource.data.assignedAssistantId == request.auth.uid
      );
    }

    // ─────────────────────────────────────────────────────────────────
    // PATIENTS & PATIENT CHATS (Authenticated Flow)
    // ─────────────────────────────────────────────────────────────────
    
    match /patients/{uid} {
      allow get: if true;
      allow create, update: if isAuth() && request.auth.uid == uid;
      
      match /medical_history/{historyId} {
        allow read: if isAuth() && (request.auth.uid == uid || isClinicalStaff(resource.data.businessId));
        allow create: if isAuth() && request.auth.uid == uid;
      }
    }

    match /patient_chats/{chatId} {
      allow read, write: if isAuth() && (
        isClinicalStaff(resource.data.businessId) || 
        request.auth.uid == resource.data.patientUid
      );
      allow create: if isAuth() && request.auth.uid == request.resource.data.patientUid;

      match /messages/{messageId} {
        allow read, write: if isAuth() && (
          isClinicalStaff(get(/databases/$(database)/documents/patient_chats/$(chatId)).data.businessId) ||
          request.auth.uid == get(/databases/$(database)/documents/patient_chats/$(chatId)).data.patientUid
        );
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
